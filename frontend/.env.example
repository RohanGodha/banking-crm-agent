# ---------------------------------------------------------------------------
# Frontend environment variables (Vite). Copy to .env.local for local dev.
# .env.local is gitignored — never commit real phone numbers to a public repo.
# ---------------------------------------------------------------------------

# Map demo customers (by first name) to real WhatsApp test numbers so the
# "Send on WhatsApp" button opens a real chat. Without this, hero customers use
# synthetic seed numbers and WhatsApp may show "not on WhatsApp".
#
# Format: digits only, INCLUDING country code, no "+" / spaces / dashes.
#   India example: 919876543210  (91 + 10-digit number)
#
# Set the real values in .env.local locally, and in your Vercel project's
# Environment Variables for the deployed demo.
VITE_DEMO_PHONES={"Priya":"910000000000","Aarav":"910000000000","Ananya":"910000000000","Vikram":"910000000000","Neha":"910000000000"}
