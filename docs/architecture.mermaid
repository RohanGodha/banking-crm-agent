%% Render with the Mermaid CLI or any Markdown viewer that supports Mermaid.
%% mmdc -i docs/architecture.mermaid -o docs/architecture.png

flowchart LR
    subgraph "Client (Vercel)"
        UI[React + Vite + shadcn UI]
        Login[/Login: password gate/]
        Dash[/Dashboard: 3-pane/]
        SSE>"@microsoft/fetch-event-source"]
        UI --> Login --> Dash
        Dash -- "SSE + X-Access-Token" --> SSE
    end

    subgraph "Backend (Render Web Service)"
        Auth[Auth middleware]
        Chat[/POST /chat/stream/]
        Trace[/GET /trace/:id/]
        Tools[/GET /tools/]
        Customers[/GET /customers/:id/]
        Health[/GET /healthz/]
        SSE --> Auth --> Chat
        Chat --> Orchestrator
        subgraph "Agent DAG"
            Planner --> Executor
            Executor --> Critic
            Critic -- "replan" --> Executor
            Critic --> Synth
            Synth --> MsgGen
            MsgGen --> Resp
            Resp --> Chat
        end
        Orchestrator --> Planner
    end

    subgraph "Infra ports + adapters"
        DS[DataSource port]
        LLM[LLMClient port]
        RAG[Hybrid Retriever]
        Cache[(SQLite tool_cache)]
        Executor --> DS
        Executor --> RAG
        Planner -.-> LLM
        Critic -.-> LLM
        Synth -.-> LLM
        MsgGen -.-> LLM
        Resp --> Cache
    end

    subgraph "External (free tier)"
        DBX[(Databricks Delta)]
        SQL[(SQLite WAL)]
        Chroma[(Chroma embeddings)]
        Gemini[Gemini 2.0 Flash]
        Groq[Groq Llama 3.3 70B]
        Mock[Mock LLM offline]
    end

    DS -- "primary, 5s timeout" --> DBX
    DS -- "failover, breaker 60s" --> SQL
    RAG --> Chroma
    LLM -- "reasoning JSON" --> Gemini
    LLM -- "generation / failover" --> Groq
    LLM -- "no-key fallback" --> Mock

    Resp --> Trace
    Health -.-> Self[(Self-ping keep-alive)]
