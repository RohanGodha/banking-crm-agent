# ===========================================================================
# banking-crm-agent — environment variables
# Copy to backend/.env (local) or set in Render dashboard (prod)
# ===========================================================================

# --- App ---
APP_NAME=banking-crm-agent
APP_ENV=development                  # development | production
APP_PASSWORD=shared                   # shared password gate (clients send X-Access-Token)
APP_CORS_ORIGINS=http://localhost:5173,https://banking-crm-agent.vercel.app
LOG_LEVEL=INFO

# --- LLM Providers ---
# At least one of these should be set. The router will gracefully degrade to
# the deterministic "mock" provider if all are missing — useful for offline dev.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_EMBED_MODEL=text-embedding-004

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Data Layer ---
# If DATABRICKS_* is set, the FailoverSource will try Databricks first.
# Otherwise SQLite is used directly.
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=banking_crm
DATABRICKS_SCHEMA=core
DATABRICKS_TIMEOUT_SECONDS=5

SQLITE_PATH=./data/app.db
CHROMA_DIR=./data/chroma

# --- Agent ---
AGENT_MAX_ITERATIONS=6
AGENT_TOP_K_CANDIDATES=10
AGENT_TOOL_TIMEOUT_SECONDS=15

# --- Self-ping keep-alive (Render free tier) ---
SELF_PING_URL=
SELF_PING_INTERVAL_SECONDS=600
